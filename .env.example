# ============================================================
# TradeSecurix — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to source control.

# ============================================================
# CLERK AUTHENTICATION
# https://dashboard.clerk.com
# ============================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Clerk redirect URLs (adjust for production)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ============================================================
# STRIPE PAYMENTS
# https://dashboard.stripe.com
# ============================================================
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Stripe Webhook Secret (from Stripe CLI or Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# -- Document Analysis Plan Price IDs --
# Create products & prices in the Stripe Dashboard, then paste the price IDs below
STRIPE_DOC_STARTER_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_DOC_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_DOC_ENTERPRISE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# -- Company Verification Plan Price IDs --
STRIPE_VERIFY_BASIC_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_VERIFY_ADVANCED_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_VERIFY_GLOBAL_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx

# ============================================================
# APP CONFIG
# ============================================================
# Your deployment URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================
# DATABASE (optional — add when connecting a real database)
# e.g. Supabase, PlanetScale, Neon, MongoDB Atlas
# ============================================================
# DATABASE_URL=postgresql://user:password@host:5432/tradesecurix
